{% extends 'base.html.twig' %}

{% block title %}Partage de notes{% endblock %}

{% block body %}
<div class="app-container">

    <header class="page-header">
        <h1 class="page-title">Partage de notes</h1>
    </header>

    {% if partages is not empty %}
        {% for partage in partages %}
            <article class="note-card">
                <h4 class="note-title">{{ partage.note.title }}</h4>
                <p>{{ partage.note.content|length > 100 ? partage.note.content|slice(0, 100) ~ '...' : partage.note.content }}</p>
                
                <p>
                    Statut : 
                    {% if partage.note.statut == 'violatesRules' %}
                        <span style="color:red; font-weight:bold;">Partage Indisponible</span>
                    {% else %}
                        Partager
                    {% endif %}
                </p>

                {% if partage.note.statut != 'violatesRules' %}
                    <a href="{{ path('note_share', {'id': partage.note.id}) }}" 
                       class="btn btn-primary rounded-btn mt-2">
                        Partager cette note
                    </a>
                {% else %}
                    <button class="btn btn-primary rounded-btn mt-2" disabled>
                        Désolé, Vous ne pouvez pas partager de notes pour le moment!
                    </button>
                {% endif %}
                
                <small>Partagé le : {{ partage.datePartage|date('d/m/Y H:i') }}</small>
            </article>
        {% endfor %}
    {% else %}
        <div class="note-card text-center">
            <p>Oops, aucune note partagée pour le moment!</p>
        </div>
    {% endif %}

</div>
{% endblock %}

