{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
<div class="account-container">

    <div class="account-card">

        <h1 class="account-title">Mon compte</h1>

        <div class="account-info">
            <p>
                Connecté en tant que <strong>{{ app.user.prenom }}</strong><br>
                <span class="account-email">{{ app.user.email }}</span>
            </p>
            <small class="account-note">
                Certaines fonctionnalités ne sont pas disponibles pour le moment.
            </small>
        </div>

        <div class="account-section">

            <div class="account-item disabled">
                <img src="https://cdn-icons-png.freepik.com/512/8452/8452627.png" class="account-icon">
                <div class="account-text">
                    <h3>Mot de passe</h3>
                    <p>La modification du mot de passe est actuellement indisponible.</p>
                </div>
            </div>

            <div class="account-item">
    <a href="{{ path('app_note') }}" class="account-link">
        <img src="https://cdn-icons-png.freepik.com/512/8452/8452627.png" class="account-icon">
        <div class="account-text">
            <h3>Mes notes</h3>
            <p>Gérer vos notes.</p>
        </div>
    </a>
</div>

            //<div class="account-item disabled">
                <img src="https://cdn-icons-png.freepik.com/512/8452/8452627.png" class="account-icon">
                <div class="account-text">
                    <h3>Supprimer mon compte</h3>
                    <p>La suppression du compte est actuellement indisponible.</p>
                </div>
            </div>

        </div>

        <a href="{{ path('app_logout') }}" class="logout-btn" id="logoutBtn">
            Se déconnecter
        </a>

    </div>

</div>

<script>
document.getElementById('logoutBtn').addEventListener('click', function(e) {
    e.preventDefault();

    const btn = this;

    btn.innerHTML = '<span class="spinner"></span> Déconnexion...';
    btn.style.pointerEvents = 'none';

    setTimeout(() => {
        window.location.href = btn.href;
    }, 10000);
});
</script>

{% endblock %} 