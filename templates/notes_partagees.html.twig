{% extends 'base.html.twig' %}

{% block body %}
<div class="app-container">

    <header class="page-header">
        <h1 class="page-title">Notes partagées</h1>
    </header>

    {% if notes|length > 0 %}
        <div class="notes-grid">
            {% for note in notes %}
                <article class="note-card">
                    <h2 class="note-title">{{ note.title }}</h2>

                    <a href="{{ path('note_show', {id: note.id}) }}" 
                       class="btn btn-primary rounded-btn" 
                       aria-label="Voir la note {{ note.title }}">
                        Voir la note partagée
                    </a>
                </article>
            {% endfor %}
        </div>
    {% else %}
        <div class="note-card note-empty text-center">
            <p>Oops, aucune note partagée pour le moment!</p>
        </div>
    {% endif %}

</div>
{% endblock %}